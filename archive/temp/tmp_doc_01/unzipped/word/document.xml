w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>支持环境、测试账户、角色、目标字段配置。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>工作流模式生成 Workflow Draft；接口模式生成 Test Run Draft/Preconfigured Runs。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/></w:pPr><w:r><w:t>所有生成产物都可以继续编辑后再转正。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>4. 端到端总流程</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t>Burp 插件开始录制 -&gt; 实时上传请求/响应对 -&gt; BSTG 后端落库并做轻量解析 -&gt; 前端草稿页确认 -&gt; 生成正式资产或保持草稿等待补配。</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblStyle w:val="TableGrid"/><w:tblW w:type="auto" w:w="0"/><w:jc w:val="center"/><w:tblLook w:firstColumn="1" w:firstRow="1" w:lastColumn="0" w:lastRow="0" w:noHBand="0" w:noVBand="1" w:val="04A0"/></w:tblPr><w:tblGrid><w:gridCol w:w="3360"/><w:gridCol w:w="3360"/><w:gridCol w:w="3360"/></w:tblGrid><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/><w:shd w:fill="D9EAF7"/></w:tcPr><w:p><w:r><w:t>阶段</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/><w:shd w:fill="D9EAF7"/></w:tcPr><w:p><w:r><w:t>主责任模块</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/><w:shd w:fill="D9EAF7"/></w:tcPr><w:p><w:r><w:t>结果</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r><w:t>创建录制会话</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r><w:t>Burp 插件 + BSTG API</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r><w:t>得到 session_id 与模式</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r><w:t>采集与上报</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3360"/><w:vAlign w:val="center"/></w:tcPr><w: